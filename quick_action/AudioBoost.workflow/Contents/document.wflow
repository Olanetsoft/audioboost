				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>Run Shell Script</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>APP_PATH=$(mdfind "kMDItemCFBundleIdentifier == 'com.olanetsoft.audioboost'" 2&gt;/dev/null | head -1)
if [ -z "$APP_PATH" ]; then APP_PATH="/Applications/AudioBoost.app"; fi
if [ ! -d "$APP_PATH" ]; then
  osascript -e 'display alert "AudioBoost not found" message "Install /Applications/AudioBoost.app and try again." as critical'
  exit 1
fi
"$APP_PATH/Contents/MacOS/AudioBoost" --cli "$@"</string>
					<key>CheckedForUserDefaultShell</key>
					<true/>
					<key>inputMethod</key>
					<integer>1</integer>
					<key>shell</key>
					<string>/bin/bash</string>
					<key>source</key>
					<string></string>
				</dict>
